<Window x:Class="DriveFlip.Views.StyledDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="#2B2B3D" CornerRadius="10"
            BorderBrush="#50506A" BorderThickness="1"
            MinWidth="400" MaxWidth="480">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.7" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with colored left accent bar -->
            <Border Grid.Row="0" Background="#363650"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel>
                    <Border x:Name="AccentBar" DockPanel.Dock="Left"
                            Width="4" Background="{StaticResource AccentBlueBrush}"
                            CornerRadius="10,0,0,0"/>
                    <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E0E0E0" Margin="16,14,20,14"/>
                </DockPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto"
                          Margin="24,18,24,18">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                           Foreground="#F0F0F0" LineHeight="20"/>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#363650"
                    CornerRadius="0,0,10,10" Padding="20,12">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
