<Window x:Class="DriveFlip.Views.ListingExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        Width="640" Height="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="#2B2B3D" CornerRadius="10"
            BorderBrush="#50506A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.7" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#363650"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel>
                    <Border DockPanel.Dock="Left"
                            Width="4" Background="{StaticResource AccentBlueBrush}"
                            CornerRadius="10,0,0,0"/>
                    <TextBlock Text="Export for Listing" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E0E0E0" Margin="16,14,20,14"/>
                </DockPanel>
            </Border>

            <!-- Body: two columns -->
            <Grid Grid.Row="1" Margin="16,12,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: field list + reorder buttons -->
                <DockPanel Grid.Column="0">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,8,0,0">
                        <ui:Button Content="▲" Padding="10,4" Margin="0,0,6,0"
                                   Click="MoveUp_Click" ToolTip="Move field up"
                                   Appearance="Secondary"/>
                        <ui:Button Content="▼" Padding="10,4"
                                   Click="MoveDown_Click" ToolTip="Move field down"
                                   Appearance="Secondary"/>
                    </StackPanel>
                    <ListBox x:Name="FieldList"
                             Background="Transparent"
                             BorderBrush="#50506A" BorderThickness="1"
                             SelectionMode="Single"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="4">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#3A3A55"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#33335A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                          Content="{Binding Label}"
                                          Foreground="#E0E0E0" FontSize="12.5"
                                          Margin="2,1"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Right: live preview -->
                <TextBox x:Name="PreviewBox" Grid.Column="1" Margin="12,0,0,0"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11.5"
                         Foreground="#D0D0D0" Background="#1E1E2E"
                         BorderBrush="#50506A" BorderThickness="1"
                         Padding="10,8"/>
            </Grid>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="#363650"
                    CornerRadius="0,0,10,10" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel" Padding="24,8" Margin="0,0,8,0"
                               Click="Cancel_Click" Appearance="Secondary" Cursor="Hand"/>
                    <ui:Button Content="Copy" Padding="24,8"
                               Click="Copy_Click" Appearance="Primary" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
