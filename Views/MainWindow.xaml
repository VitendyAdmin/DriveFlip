<ui:FluentWindow x:Class="DriveFlip.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriveFlip.ViewModels"
        xmlns:models="clr-namespace:DriveFlip.Models"
        xmlns:converters="clr-namespace:DriveFlip.Converters"
        Title="DriveFlip &#x2014; Surface Check &amp; Drive Prep"
        Width="1020" Height="760" MinWidth="850" MinHeight="640"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel/>
    </ui:FluentWindow.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="DriveFlip"/>

            <!-- Branded Header -->
            <Border Grid.Row="1" Padding="20,10,20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="DriveFlip" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                        <TextBlock Text="Surface checker &amp; drive prep for resale"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="Refresh Drives" Appearance="Secondary"
                                   Command="{Binding RefreshDrivesCommand}" Margin="0,0,4,0"/>
                        <ui:Button Content="Save Report" Appearance="Secondary"
                                   Command="{Binding SaveReportCommand}" Margin="0,0,4,0"/>
                        <ui:Button x:Name="GearButton" Command="{Binding ToggleSettingsCommand}"
                                   Appearance="Secondary" Padding="8,6" ToolTip="Settings">
                            <ui:SymbolIcon Symbol="Settings24"/>
                        </ui:Button>
                        <Popup IsOpen="{Binding IsSettingsOpen}"
                               PlacementTarget="{Binding ElementName=GearButton}"
                               Placement="Bottom" StaysOpen="True"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="#2B2B3D" BorderBrush="#50506A" BorderThickness="1"
                                    CornerRadius="8" Padding="16,14" Width="280" Margin="0,-1,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Surface check:"
                                                   FontSize="11.5"
                                                   VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding DurationOptions}"
                                                  SelectedItem="{Binding SurfaceCheckDurationMinutes}"
                                                  ItemStringFormat="{}{0} min" Margin="0,0,0,6"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Head/tail wipe:"
                                                   FontSize="11.5"
                                                   VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding HeadTailSizeOptions}"
                                                  SelectedItem="{Binding HeadTailSizeGB}"
                                                  ItemStringFormat="{}{0} GB" Margin="0,0,0,6"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Scatter wipe:"
                                                   FontSize="11.5"
                                                   VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding DurationOptions}"
                                                  SelectedItem="{Binding ScatterDurationMinutes}"
                                                  ItemStringFormat="{}{0} min" Margin="0,0,0,6"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Passes:"
                                                   FontSize="11.5"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding PassOptions}"
                                                  SelectedItem="{Binding NumberOfPasses}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Drive List -->
            <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="0"
                     VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Physical Drives" FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ToggleButton Content="External Only"
                                              IsChecked="{Binding ShowExternalOnly}"
                                              Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                              Cursor="Hand"/>
                                <ui:Button Content="All" Appearance="Secondary"
                                        Command="{Binding SelectAllCommand}" Padding="10,4" FontSize="11"
                                        Margin="0,0,6,0"/>
                                <ui:Button Content="None" Appearance="Secondary"
                                        Command="{Binding DeselectAllCommand}" Padding="10,4" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="6">
                        <ItemsControl ItemsSource="{Binding Drives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Margin="4,3" Padding="12,10"
                                            Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectDriveCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInfoSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 0: Checkbox + Drive Name -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                          IsEnabled="{Binding IsSelectable}"
                                                          VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Drive.DisplayName}"
                                                               FontSize="13" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding Drive.InterfaceType}"
                                                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding Drive.DriveLettersSummary}"
                                                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Margin="0,0,12,0"/>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource AccentAmberBrush}"
                                                                   Visibility="{Binding Drive.IsSystemDrive, Converter={StaticResource BoolToVis}}"
                                                                   Text="SYSTEM" FontWeight="Bold"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Visibility="{Binding Drive.IsRemovable, Converter={StaticResource BoolToVis}}"
                                                                   Text="USB/Removable" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                                        Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Passed}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="PASS"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Passed}" Value="False">
                                                                        <Setter Property="Text" Value="ISSUES"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Row 1: Progress bar (when running) -->
                                            <Grid Grid.Row="1" Margin="0,8,0,0"
                                                  Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="3" Height="6">
                                                    <Border Background="{StaticResource AccentBlueBrush}"
                                                            CornerRadius="3" HorizontalAlignment="Left">
                                                        <Border.Width>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <converters:PercentToWidthConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="Progress"/>
                                                                <Binding Path="ActualWidth"
                                                                         RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Border>

                                                <Grid Grid.Row="1" Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                                                               FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SpeedText}"
                                                               FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="12,0,0,0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TimeRemainingText}"
                                                               FontSize="11" Foreground="{StaticResource AccentBlueBrush}"
                                                               Margin="12,0,0,0"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Row 2: Stats (when running) -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="11" Margin="0,0,16,0">
                                                    <Run Text="Errors: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Run Text="{Binding ErrorCount, Mode=OneWay}"
                                                         Foreground="{Binding ErrorCount, Converter={StaticResource HealthColor}}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11">
                                                    <Run Text="Data found: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Run Text="{Binding DataPresencePercent, StringFormat={}{0:F1}%, Mode=OneWay}"
                                                         Foreground="{Binding DataPresencePercent, Converter={StaticResource DataPresenceColor}}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Row 3: Completed status text -->
                                            <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                                                       FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,4,0,0">
                                                <TextBlock.Visibility>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <converters:CompletedNotRunningConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="IsComplete"/>
                                                        <Binding Path="IsRunning"/>
                                                    </MultiBinding>
                                                </TextBlock.Visibility>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Drive Info Panel (Row 2) -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"
                            MaxHeight="400"
                            Visibility="{Binding DataContext.HasSelectedDrive, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource BoolToVis}}">
                        <TabControl BorderThickness="0" Padding="0">

                            <!-- Info Tab -->
                            <TabItem Header="Info">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                                    <Grid DataContext="{Binding DataContext.SelectedDrive, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                          Margin="14,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Model}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Serial" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SerialNumber}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Interface" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding InterfaceType}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Firmware" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding FirmwareVersion, TargetNullValue=N/A, FallbackValue=N/A}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Size" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding DisplaySize}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Partitions" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Partitions.Count, StringFormat={}{0} partition(s)}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Drive Letters" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding DriveLettersSummary}" FontSize="11" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Status" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding Status}" FontSize="11" Margin="0,0,0,4"/>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Health Tab -->
                            <TabItem Header="Health">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                                    <StackPanel DataContext="{Binding DataContext.SelectedDriveHealth, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                Margin="14,10">

                                        <!-- Loading indicator when health is null -->
                                        <TextBlock Text="Loading health data..."
                                                   FontSize="11" FontStyle="Italic"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding DataContext.SelectedDriveHealth, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource NullToVis}, ConverterParameter=Invert}"/>

                                        <!-- Basic Health Rows -->
                                        <Grid Visibility="{Binding Converter={StaticResource NullToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Health Status" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding HealthStatus}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Media Type" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding MediaType}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Bus Type" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding BusType}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Spindle Speed" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding SpindleSpeedDisplay}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Temperature" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding TemperatureDisplay}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Power-On Hours" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding PowerOnHoursDisplay}" FontSize="11" Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Read / Write Errors" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="6" Grid.Column="2" FontSize="11" Margin="0,0,0,4">
                                                <Run Text="{Binding ReadErrorsDisplay, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding WriteErrorsDisplay, Mode=OneWay}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="SSD Wear" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding WearDisplay}" FontSize="11" Margin="0,0,0,4"/>
                                        </Grid>

                                        <!-- Get SMART Data Button (visible when not yet queried) -->
                                        <ui:Button Content="Get SMART Data" Appearance="Secondary"
                                                   Command="{Binding DataContext.GetSmartDataCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                   HorizontalAlignment="Left" Margin="0,10,0,0" Padding="12,6"
                                                   Visibility="{Binding SmartDataQueried, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                                        <!-- Loading indicator during SMART query -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                                    Visibility="{Binding DataContext.IsLoadingSmartData, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource BoolToVis}}">
                                            <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="Reading and interpreting SMART data..."
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- SMART Results (visible after query) -->
                                        <StackPanel Visibility="{Binding SmartDataQueried, Converter={StaticResource BoolToVis}}"
                                                    Margin="0,10,0,0">

                                            <!-- Risk Badge -->
                                            <Border CornerRadius="4" Padding="10,6" HorizontalAlignment="Left"
                                                    Background="{Binding RiskLevel, Converter={StaticResource RiskLevelColor}}">
                                                <TextBlock Text="{Binding RiskLevel, Converter={StaticResource RiskLevelText}}"
                                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            </Border>

                                            <!-- Risk Summary -->
                                            <TextBlock Text="{Binding RiskSummary}" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,6,0,0"/>

                                            <!-- Separator -->
                                            <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,8,0,8"/>

                                            <!-- Extended Counters (Tier 1) -->
                                            <TextBlock Text="Extended Counters" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"
                                                       Foreground="{StaticResource AccentBlueBrush}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Read Errors (Corrected)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ReadErrorsCorrectedDisplay}" FontSize="11" Margin="0,0,0,3"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Read Errors (Uncorrected)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ReadErrorsUncorrectedDisplay}" FontSize="11" Margin="0,0,0,3"
                                                           Foreground="{Binding ReadErrorsUncorrected, Converter={StaticResource HealthColor}}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Write Errors (Corrected)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding WriteErrorsCorrectedDisplay}" FontSize="11" Margin="0,0,0,3"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Write Errors (Uncorrected)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding WriteErrorsUncorrectedDisplay}" FontSize="11" Margin="0,0,0,3"
                                                           Foreground="{Binding WriteErrorsUncorrected, Converter={StaticResource HealthColor}}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Read Latency" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ReadLatencyMaxDisplay}" FontSize="11" Margin="0,0,0,3"/>

                                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Max Write Latency" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding WriteLatencyMaxDisplay}" FontSize="11" Margin="0,0,0,3"/>

                                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Max Flush Latency" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding FlushLatencyMaxDisplay}" FontSize="11" Margin="0,0,0,3"/>

                                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Start/Stop Cycles" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding StartStopCycleCountDisplay}" FontSize="11" Margin="0,0,0,3"/>
                                            </Grid>

                                            <!-- SMART Attributes Table (SATA only) -->
                                            <StackPanel Visibility="{Binding SmartSupported, Converter={StaticResource BoolToVis}}"
                                                        Margin="0,8,0,0">
                                                <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="SMART Attributes" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"
                                                           Foreground="{StaticResource AccentBlueBrush}"/>

                                                <!-- Header Row -->
                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="ID" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Grid.Column="1" Text="Name" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Grid.Column="2" Text="Cur" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Grid.Column="3" Text="Worst" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Grid.Column="4" Text="Raw" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding SmartAttributes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1,0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="45"/>
                                                                    <ColumnDefinition Width="45"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Id}" FontSize="10">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFailurePredictive}" Value="True">
                                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="10" TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFailurePredictive}" Value="True">
                                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="2" Text="{Binding CurrentValue}" FontSize="10"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding WorstValue}" FontSize="10"/>
                                                                <TextBlock Grid.Column="4" Text="{Binding RawValue}" FontSize="10"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- NVMe note (when SMART not supported) -->
                                            <TextBlock Text="Raw SMART attributes are not available for NVMe drives."
                                                       FontSize="10" FontStyle="Italic" Margin="0,8,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding SmartSupported, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </ui:Card>

            <!-- Right: Actions + Settings Panel -->
            <ui:Card Grid.Column="1" Padding="0"
                     VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,14">

                        <!-- Spinning Disk Animation (visible during operations) -->
                        <Grid Width="130" Height="130" HorizontalAlignment="Center" Margin="0,0,0,16"
                              Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                            <!-- Disk platter -->
                            <Ellipse Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#4A4A60" Offset="0"/>
                                        <GradientStop Color="#3A3A50" Offset="0.5"/>
                                        <GradientStop Color="#2E2E42" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- Track rings -->
                            <Ellipse Width="100" Height="100" Stroke="#45456A" StrokeThickness="0.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="80" Height="80" Stroke="#45456A" StrokeThickness="0.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="60" Height="60" Stroke="#45456A" StrokeThickness="0.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="40" Height="40" Stroke="#45456A" StrokeThickness="0.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Center spindle -->
                            <Ellipse Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Spinning animal -->
                            <Canvas Width="130" Height="130" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Canvas.RenderTransform>
                                    <RotateTransform x:Name="DiskRotation" Angle="0"/>
                                </Canvas.RenderTransform>
                                <TextBlock Text="{Binding AnimationEmoji}" FontSize="18"
                                           Canvas.Left="56" Canvas.Top="2"/>
                            </Canvas>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="DiskRotation"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:2.5"
                                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                        </Grid>

                        <!-- Cancel (when running) -->
                        <ui:Button Content="Cancel Operation" Appearance="Secondary"
                                Command="{Binding CancelCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,12"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>

                        <!-- Settings Section (hidden when running) -->
                        <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">

                            <!-- Surface Check Section -->
                            <TextBlock Text="Surface Check" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10">
                                Randomly samples sectors to detect read errors and residual data.
                                Safe — read-only operation.
                            </TextBlock>
                            <ui:Button Content="Run Surface Check" Appearance="Primary"
                                    Command="{Binding RunSurfaceCheckCommand}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,0,0,14"/>

                            <!-- Wipe Section -->
                            <TextBlock Text="Wipe" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentRedBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10">
                                Overwrites drive data. This permanently destroys all data and cannot be undone.
                            </TextBlock>

                            <!-- Wipe Mode -->
                            <TextBlock Text="Wipe mode:" FontSize="12" Margin="0,0,0,4"/>
                            <RadioButton Content="Smart Wipe (head + tail + scatter)"
                                         IsChecked="{Binding SelectedWipeMode, Converter={StaticResource EnumToBool}, ConverterParameter=SmartWipe}"
                                         GroupName="WipeMode"/>
                            <RadioButton Content="Full Wipe (every sector)"
                                         IsChecked="{Binding SelectedWipeMode, Converter={StaticResource EnumToBool}, ConverterParameter=FullWipe}"
                                         GroupName="WipeMode" Margin="0,3,0,8"/>

                            <!-- Fill Method -->
                            <TextBlock Text="Fill method:" FontSize="12" Margin="0,0,0,4"/>
                            <RadioButton Content="Zero fill (fast)"
                                         IsChecked="{Binding SelectedWipeMethod, Converter={StaticResource EnumToBool}, ConverterParameter=ZeroFill}"
                                         GroupName="WipeMethod"/>
                            <RadioButton Content="Random fill"
                                         IsChecked="{Binding SelectedWipeMethod, Converter={StaticResource EnumToBool}, ConverterParameter=RandomFill}"
                                         GroupName="WipeMethod"/>
                            <RadioButton Content="Random + zero (2 passes)"
                                         IsChecked="{Binding SelectedWipeMethod, Converter={StaticResource EnumToBool}, ConverterParameter=RandomThenZero}"
                                         GroupName="WipeMethod" Margin="0,3,0,8"/>

                            <!-- Verify option -->
                            <CheckBox Content="Verify after wipe"
                                      IsChecked="{Binding VerifyAfterWipe}" Margin="0,0,0,12"/>

                            <ui:Button Content="Wipe Selected Drives" Appearance="Danger"
                                    Command="{Binding RunWipeCommand}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,0,0,14"/>

                            <!-- Check &amp; Wipe Combined -->
                            <TextBlock Text="Check &amp; Wipe" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentAmberBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10">
                                Runs surface check first, then automatically wipes if the drive passes.
                                If issues are found, you'll be asked whether to continue.
                            </TextBlock>
                            <ui:Button Content="Check &amp; Wipe" Appearance="Caution"
                                    Command="{Binding RunCheckAndWipeCommand}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,0,0,14"/>

                            <!-- Tips -->
                            <ui:Card Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Tips" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" LineHeight="18">
                                        &#x2022; Run a surface check first to assess drive health&#x0a;
                                        &#x2022; Smart Wipe is fast — destroys FS structures + scatters data&#x0a;
                                        &#x2022; Full Wipe overwrites every sector (slow but thorough)&#x0a;
                                        &#x2022; System drives are automatically protected&#x0a;
                                        &#x2022; Multiple drives are processed in parallel&#x0a;
                                        &#x2022; Save reports for your records
                                    </TextBlock>
                                </StackPanel>
                            </ui:Card>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,14,0,14"/>

                            <!-- About -->
                            <ui:Card Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Pragmatic Peace of Mind" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" LineHeight="18">
                                        DriveFlip is built for the "good enough" reality of hardware recycling: since NAS data is already fragmented across multiple disks, wiping even one drive with our random-pattern pass makes reconstruction mathematically exhausting. We don't promise a forensic-proof fortress; we provide a sensible, high-speed hurdle that turns "recovering your data" into an expensive, impractical fool's errand for the next owner.
                                    </TextBlock>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </ui:Card>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding GlobalStatus}"
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center">
                    <Run Text="Requires Administrator"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
