<UserControl x:Class="DriveFlip.Views.DriveLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:DriveFlip.Localization"
             xmlns:models="clr-namespace:DriveFlip.Models"
             AllowDrop="True" PreviewDrop="OnDrop" PreviewDragOver="OnDragOver"
             Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" MinWidth="300" MaxWidth="550"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Drive List -->
        <ui:Card Grid.Column="0" Padding="0" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="12,10,12,6">
                    <TextBlock Text="{loc:Loc DriveLog}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                </Border>

                <!-- Search + Filter -->
                <StackPanel Grid.Row="1" Margin="12,0,12,8">
                    <ui:TextBox PlaceholderText="{loc:Loc DriveLogSearch}" Margin="0,0,0,8"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <WrapPanel>
                        <ui:Button Content="{loc:Loc All}" Padding="8,4" Margin="0,0,4,4"
                                   Command="{Binding ClearStatusFilterCommand}"
                                   Appearance="{Binding StatusFilter, Converter={StaticResource NullToAppearance}}"/>
                        <ItemsControl ItemsSource="{Binding StatusOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:Button Content="{Binding Converter={StaticResource DriveLogStatusText}}"
                                               Padding="8,4" Margin="0,0,4,4"
                                               Command="{Binding DataContext.SetStatusFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"
                                               Foreground="{Binding Converter={StaticResource DriveLogStatusColor}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </StackPanel>

                <!-- Drive List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredEntries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DriveLogEntry}">
                            <Border Padding="10,8" BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Model}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0">
                                            <Run Text="s/n "/>
                                            <Run Text="{Binding SerialNumber, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0">
                                            <Run Text="{Binding DisplaySize, Mode=OneWay}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding LastSeenUtc, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Top"
                                            CornerRadius="4" Padding="6,3" Margin="8,0,0,0"
                                            Background="{Binding Status, Converter={StaticResource DriveLogStatusColor}, ConverterParameter=Background}">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource DriveLogStatusText}}"
                                                   FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer -->
                <Border Grid.Row="3" Padding="12,8" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DriveCountText}"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" Content="{loc:Loc DriveLogExport}" Padding="10,4"
                                   Appearance="Secondary" Command="{Binding ExportCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </ui:Card>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="6" Background="Transparent" VerticalAlignment="Stretch"/>

        <!-- RIGHT: Detail Panel -->
        <ui:Card Grid.Column="2" Padding="0" Margin="6,0,0,0"
                 VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">

            <!-- No Selection Placeholder -->
            <Grid>
                <TextBlock Text="{loc:Loc DriveLogSelectEntry}" FontSize="14"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                <!-- Detail Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16"
                              Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel>

                        <!-- Identity Section -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedEntry.Model}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0">
                                    <Run Text="s/n "/>
                                    <Run Text="{Binding SelectedEntry.SerialNumber, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Appearance="Danger" Padding="8,4"
                                       Command="{Binding DeleteEntryCommand}" ToolTip="{loc:Loc DriveLogDelete}">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                            </ui:Button>
                        </Grid>

                        <!-- Identity Grid -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc LabelManufacturer}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEntry.Manufacturer}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc LabelCapacity}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEntry.DisplaySize}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc LabelMediaType}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEntry.MediaType}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc LabelInterface}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEntry.InterfaceType}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc LabelFirmware}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedEntry.FirmwareVersion}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc LabelPartNumber}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedEntry.PartNumber}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Loc DriveLogFirstSeen}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedEntry.FirstSeenUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontSize="11" Margin="0,0,0,4"/>
                        </Grid>

                        <!-- Status -->
                        <Border Height="1" Background="#50506A" Margin="0,12,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc DriveLogStatus}" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="StatusComboBox" ItemsSource="{Binding StatusOptions}" Width="140"
                                      SelectedItem="{Binding SelectedEntry.Status, Mode=OneWay}"
                                      SelectionChanged="StatusComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource DriveLogStatusText}}"
                                                   Foreground="{Binding Converter={StaticResource DriveLogStatusColor}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Health Snapshot -->
                        <Border Height="1" Background="#50506A" Margin="0,12,0,12"/>
                        <TextBlock Text="{loc:Loc DriveLogHealth}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Visibility="{Binding SelectedEntry.HealthSnapshot, Converter={StaticResource NullToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc LabelHealthStatus}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.HealthStatus}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc DriveLogRisk}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.RiskLevel, Converter={StaticResource RiskLevelText}}"
                                       Foreground="{Binding SelectedEntry.HealthSnapshot.RiskLevel, Converter={StaticResource RiskLevelColor}}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc LabelTemperature}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.Temperature, TargetNullValue='N/A', StringFormat='{}{0}°C'}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc LabelPowerOnHours}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.PowerOnHours, TargetNullValue='N/A', StringFormat='{}{0:N0} hrs'}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc LabelReadErrors}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.ReadErrors, TargetNullValue='N/A'}" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc LabelWriteErrors}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedEntry.HealthSnapshot.WriteErrors, TargetNullValue='N/A'}" FontSize="11" Margin="0,0,0,4"/>
                        </Grid>
                        <TextBlock Text="{loc:Loc DriveLogNoHealth}"
                                   Visibility="{Binding SelectedEntry.HealthSnapshot, Converter={StaticResource NullToVis}, ConverterParameter=Invert}"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                        <!-- Operations History -->
                        <Border Height="1" Background="#50506A" Margin="0,12,0,12"/>
                        <TextBlock Text="{loc:Loc DriveLogOperations}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding SelectedEntry.Operations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LogOperationRecord}">
                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                                            Background="#15FFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"
                                                       VerticalAlignment="Top">
                                                <Run Text="{Binding StartUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}"/>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Summary}" FontSize="10.5"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="Bold"
                                                       VerticalAlignment="Top" Margin="8,0,0,0"
                                                       Text="{Binding Passed, Converter={StaticResource BoolToPassFail}}"
                                                       Foreground="{Binding Passed, Converter={StaticResource BoolToPassFailColor}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{loc:Loc DriveLogNoOperations}"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Visibility="{Binding SelectedEntry.Operations.Count, Converter={StaticResource ZeroToVis}}"/>

                        <!-- Photos -->
                        <Border Height="1" Background="#50506A" Margin="0,12,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc DriveLogPhotos}" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <ui:Button Grid.Column="1" Appearance="Secondary" Padding="6,4"
                                       Command="{Binding AddPhotoCommand}">
                                <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                            </ui:Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SelectedEntry.Photos}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,6" CornerRadius="4" Background="#20FFFFFF"
                                            Cursor="Hand" MouseLeftButtonDown="Photo_MouseLeftButtonDown">
                                        <Grid Width="90" Height="90">
                                            <Image Source="{Binding Converter={StaticResource FilePathToThumbnail}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <ui:Button Appearance="Danger" Padding="2" Margin="0,2,2,0"
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                       Command="{Binding DataContext.RemovePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Dismiss16" FontSize="10"/>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{loc:Loc DriveLogDragPhotos}"
                                   FontSize="10.5" FontStyle="Italic"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>

                        <!-- Notes -->
                        <Border Height="1" Background="#50506A" Margin="0,12,0,12"/>
                        <TextBlock Text="{loc:Loc DriveLogNotes}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding SelectedEntry.Notes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LogNote}">
                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                                            Background="#15FFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TimestampUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                           FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{Binding Text}" FontSize="11.5" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ui:Button Grid.Column="1" Appearance="Secondary" Padding="4"
                                                       VerticalAlignment="Top" Margin="6,0,0,0"
                                                       Command="{Binding DataContext.RemoveNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Dismiss16" FontSize="10"/>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add Note -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" PlaceholderText="{loc:Loc DriveLogAddNotePlaceholder}"
                                        Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}"
                                        KeyDown="NoteTextBox_KeyDown"/>
                            <ui:Button Grid.Column="1" Content="{loc:Loc DriveLogAddNote}" Padding="10,6" Margin="6,0,0,0"
                                       Appearance="Primary" Command="{Binding AddNoteCommand}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
